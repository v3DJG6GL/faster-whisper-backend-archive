    {
      "name": "strip-stray-symbols",
      "label": "Strip stray symbols",
      "enabled": true,
      "locked": false,
      "seeded": true,
      "exposed": false,
      "tags": [],
      "note": "Language-agnostic. Removes stray non-linguistic symbols (quotes, brackets, math/programming glyphs) Whisper emits.",
      "type": "regex-list",
      "entries": [
        {
          "pattern": "[\\\"#$%&'()*+;<=>@\\[\\\\\\]^_`{|}~вЂћ]",
          "replacement": "",
          "label": "strip-stray-symbols",
          "note": "Removes all string.punctuation except the keep-set .,-/:?! (and вЂћ); keep-set kept so the later digit-aware strips still run."
        }
