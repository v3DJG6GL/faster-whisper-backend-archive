    {
      "name": "capitalize-letter-after-hyphen",
      "label": "Capitalize letter after hyphen",
      "enabled": true,
      "locked": false,
      "seeded": true,
      "exposed": false,
      "tags": [],
      "note": "Uppercases a lowercase letter right after a hyphen (letters only). Back half of the compound split: de-split-punctuation-keywords + dictation-map insert the '-', this fixes the casing вЂ” 'Eisen-infusion'в†’'Eisen-Infusion'.",
      "type": "callback:upper",
      "pattern": "(-)([a-zГ¤Г¶ГјГџ])"
    },
    {
      "name": "digit-and-whitespace-tidy",
      "label": "Digit + whitespace tidy",
      "enabled": true,
      "locked": true,
      "seeded": true,
      "exposed": false,
      "tags": [],
      "note": "Reassembles spaced digit groups around / , - (entries 1-3), then strips space around punctuation/brackets and collapses double-spaces (4-6).",
      "type": "regex-list",
      "entries": [
        {
          "pattern": "(\\d)\\s*([/,\\-])\\s*(\\d)",
          "replacement": "\\1\\2\\3",
          "label": "tighten-digit-separators",
          "note": "Strips spaces around a / , or - between two digits: '12 / 5'в†’'12/5'."
        },
        {
          "pattern": "(?<=\\d) +(?=\\d[/\\-])",
          "replacement": "",
          "label": "merge-digit-pair-before",
          "note": "Strips a space between digits when the second starts a /- group: '1 2/3'в†’'12/3'."
        },
        {
          "pattern": "(?<=[/\\-]\\d) +(?=\\d)",
          "replacement": "",
          "label": "merge-digit-pair-after",
          "note": "Strips a space between digits right after a /- + digit: '2/3 4'в†’'2/34'."
        },
        {
          "pattern": "[ \\t]+([,.:;!?%\\)\\]\\}])",
          "replacement": "\\1",
          "label": "space-before-closing-punct",
          "note": "Drops space/tab before closing punctuation: , . : ; ! ? % ) ] }."
        },
        {
          "pattern": "([\\(\\[\\{])[ \\t]+",
          "replacement": "\\1",
          "label": "space-after-opening-punct",
          "note": "Drops space/tab after an opening bracket: ( [ {."
        },
        {
          "pattern": "  +",
          "replacement": " ",
          "label": "collapse-multi-space",
          "note": "Collapses 2+ spaces to one."
        }
      ]
    },
