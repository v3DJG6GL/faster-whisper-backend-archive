# Virtual environment (Windows-built, ~2 GB — rebuild from requirements.txt)
venv/
.venv/

# Python bytecode
__pycache__/
*.py[cod]
*$py.class

# Test / coverage artifacts
.coverage
.coverage.*
htmlcov/
.pytest_cache/

# Local environment / secrets
.env
.env.local
*.local

# Admin-WebUI runtime overrides (the .example.json variant IS committed)
config.local.json

# Transcription error reports — durable PHI store (SQLite + WAL/SHM sidecars)
reports.local.sqlite3
reports.local.sqlite3-shm
reports.local.sqlite3-wal

# Whisper fine-tuning capture store (SQLite + WAL/SHM) and audio files
captures.local.sqlite3
captures.local.sqlite3-shm
captures.local.sqlite3-wal
captures/

# Persistent recent-transcriptions store (SQLite + WAL/SHM)
recent_transcriptions.local.sqlite3
recent_transcriptions.local.sqlite3-shm
recent_transcriptions.local.sqlite3-wal

# API key store (SQLite + WAL/SHM)
api_keys.local.sqlite3
api_keys.local.sqlite3-shm
api_keys.local.sqlite3-wal

# Usage/metrics store (SQLite + WAL/SHM)
usage.local.sqlite3
usage.local.sqlite3-shm
usage.local.sqlite3-wal

# Editor / IDE
.vscode/
.idea/
*.swp

# OS noise
.DS_Store
Thumbs.db

# Test artifacts / temp uploads
*.log
tmp/
logs/
*.wav
*.mp3
*.m4a

# Auto-downloaded / generated by install-service.ps1 (per-deployment, no need to commit)
WhisperAPI.exe
WhisperAPI.xml
WhisperAPI.wrapper.log
# Legacy NSSM era — install-service.ps1 -RemoveLocal cleans this up
nssm.exe
SIMPLIFY_NOTES.md
CODE-REVIEW_NOTES.md
SECURITY-REVIEW_NOTES.md
