# Virtual environment (Windows-built, ~2 GB — rebuild from requirements.txt)
venv/
.venv/

# Python bytecode
__pycache__/
*.py[cod]
*$py.class

# Local environment / secrets
.env
.env.local
*.local

# Admin-WebUI runtime overrides (the .example.json variant IS committed)
config.local.json

# Transcription error reports — durable PHI store (SQLite + WAL/SHM sidecars)
reports.local.sqlite3
reports.local.sqlite3-shm
reports.local.sqlite3-wal

# Whisper fine-tuning capture store (SQLite + WAL/SHM) and audio files
captures.local.sqlite3
captures.local.sqlite3-shm
captures.local.sqlite3-wal
captures/

# Editor / IDE
.vscode/
.idea/
*.swp

# OS noise
.DS_Store
Thumbs.db

# Test artifacts / temp uploads
*.log
tmp/
logs/
*.wav
*.mp3
*.m4a

# Auto-downloaded / generated by install-service.ps1 (per-deployment, no need to commit)
WhisperAPI.exe
WhisperAPI.xml
WhisperAPI.wrapper.log
# Legacy NSSM era — install-service.ps1 -RemoveLocal cleans this up
nssm.exe
